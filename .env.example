# Cal.com: enlace para el modal de reservas (ej: blueroyale o blueroyale/event-type)
PUBLIC_CAL_LINK=blueroyale

# Vercel Blob: token para subir el video del hero (crear Blob store en Vercel → Storage).
# Solo necesario para ejecutar scripts/upload-hero-video.mjs
# BLOB_READ_WRITE_TOKEN=

# Hero: video de fondo del inicio. URL del MP4 (p. ej. de Vercel Blob tras subir con el script).
# Dejar vacío para usar la imagen por defecto.
# PUBLIC_HERO_VIDEO=

# Hero: imagen del primer frame del video (poster/fallback). Generar con: npm run extract-hero-poster -- <video.mp4>
# PUBLIC_HERO_POSTER=/hero-poster.jpg

# Sanity: solo necesario si usas el CMS. Si no, se usan los Markdown de src/content/services.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2024-01-01

# Google: reseñas en la sección Testimonios (Places API). Place ID del negocio en Google Maps.
# PUBLIC_GOOGLE_PLACE_ID=ChIJ...
# PUBLIC_GOOGLE_PLACES_API_KEY=tu_api_key

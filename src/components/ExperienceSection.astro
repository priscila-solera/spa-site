---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="experiencia"
  class="experience-section scroll-mt-20 bg-white px-4 pt-12 pb-6 sm:px-6 sm:pt-20 sm:pb-20 lg:px-8"
  aria-labelledby="experiencia-heading"
>
  <div class="mx-auto max-w-7xl relative z-10">
    <div
      class="mb-16 grid gap-6 rounded-2xl bg-gray-50 px-6 py-8 shadow-spa-soft sm:grid-cols-2 lg:grid-cols-4 sm:px-8"
      data-scroll-reveal="up"
    >
      <div>
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-beige-600">
          {t('experience.satisfaction')}
        </p>
        <p class="mt-2 font-serif text-2xl tracking-tight text-secondary">100%</p>
        <p class="mt-1 text-sm text-beige-700">{t('experience.satisfaction.desc')}</p>
      </div>
      <div>
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-beige-600">
          {t('experience.years')}
        </p>
        <p class="mt-2 font-serif text-2xl tracking-tight text-secondary">10+</p>
        <p class="mt-1 text-sm text-beige-700">{t('experience.years.desc')}</p>
      </div>
      <div>
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-beige-600">
          {t('experience.treatments')}
        </p>
        <p class="mt-2 font-serif text-2xl tracking-tight text-secondary">30+</p>
        <p class="mt-1 text-sm text-beige-700">{t('experience.treatments.desc')}</p>
      </div>
      <div>
        <p class="text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-beige-600">
          {t('experience.booking')}
        </p>
        <p class="mt-2 font-serif text-2xl tracking-tight text-secondary">24/7</p>
        <p class="mt-1 text-sm text-beige-700">{t('experience.booking.desc')}</p>
      </div>
    </div>
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div
        class="order-2 lg:order-1"
        data-scroll-reveal="left"
      >
        <p class="editorial-subtitle">{t('experience.retreat.subtitle')}</p>
        <h2 id="experiencia-heading" class="section-heading mt-2">
          {t('experience.retreat.title')}
        </h2>
        <div class="mt-6 space-y-6">
          <p class="text-base leading-relaxed text-beige-600">
            {t('experience.retreat.desc1')}
          </p>
          <p class="text-base leading-relaxed text-beige-600 border-l-2 border-accent/60 pl-5">
            {t('experience.retreat.desc2')}
          </p>
        </div>
        <div class="mt-8">
          <a
            href="#reserva-home"
            class="experience-retreat-cta inline-flex items-center rounded-full border-2 border-accent bg-accent px-6 py-3 text-sm font-medium text-white shadow-spa transition-all duration-300 hover:bg-accent/90 hover:border-accent/90"
          >
            {t('experience.retreat.cta')}
          </a>
        </div>
      </div>
      <div
        class="order-1 overflow-hidden rounded-2xl border border-black/[0.06] shadow-spa-soft lg:order-2"
        data-scroll-reveal="right"
      >
        <div
          class="parallax-layer h-full w-full"
          data-parallax
          data-parallax-speed-y="0.5"
          data-parallax-intensity="50"
        >
          <img
            src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=1200&q=80&auto=format&fit=crop"
            alt="Relaxing spa ambiance"
            class="h-full w-full scale-105 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-section {
    background-image: url('/images/fondo.PNG');
    background-repeat: no-repeat;
    /* Rama más abajo: que la punta quede claramente dentro del margen blanco */
    background-position: 10% 86%;
    background-size: min(55%, 420px) auto;
    padding-bottom: 3rem;
  }
  @media (min-width: 640px) {
    .experience-section {
      background-position: 15% 82%;
      padding-bottom: 5rem;
    }
  }
</style>

<script>
  document.querySelectorAll('.experience-retreat-cta').forEach((link) => {
    link.addEventListener('click', (e) => {
      const target = document.getElementById('reserva-home');
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });
</script>

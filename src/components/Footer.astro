---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const currentYear = new Date().getFullYear();

const phone = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '50684872727').replace(/\D/g, '');
const waMessage = encodeURIComponent(t('whatsapp.text'));
const waUrl = `https://wa.me/${phone}?text=${waMessage}`;
const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=${encodeURIComponent(waUrl)}&color=4a3728&bgcolor=fdf8f3`;
---

<footer class="border-t border-black/[0.06] bg-cream-100">
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 text-center md:grid-cols-3 md:text-left">
      <div class="max-w-xs">
        <a href={translatePath('/')} class="font-serif text-xl font-semibold tracking-tight text-beige-800 transition-colors duration-300 hover:text-accent">
          Blue Royale Spa
        </a>
        <p class="mt-3 text-sm leading-relaxed text-beige-600">
          Wellness, beauty and connection between mind, body and spirit.
        </p>
      </div>

      <div class="flex flex-col items-center gap-2">
        <a href={waUrl} target="_blank" rel="noopener noreferrer" aria-label={t('footer.whatsapp.label')}>
          <img
            src={qrUrl}
            alt="WhatsApp QR"
            width="100"
            height="100"
            class="rounded-lg opacity-80 transition-opacity duration-300 hover:opacity-100"
            loading="lazy"
          />
        </a>
        <p class="text-xs text-beige-500">{t('footer.whatsapp.label')}</p>
      </div>

      <div class="flex justify-center md:justify-end">
        <div class="flex items-center gap-4">
          <a
            href="https://www.instagram.com/blueroyalespa"
            target="_blank"
            rel="noopener noreferrer"
            class="text-beige-500 transition-colors duration-300 hover:text-accent"
            aria-label="Follow us on Instagram"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.468 2.53c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd" />
            </svg>
          </a>
          <a
            href="https://www.facebook.com/blueroyalespa"
            target="_blank"
            rel="noopener noreferrer"
            class="text-beige-500 transition-colors duration-300 hover:text-accent"
            aria-label="Follow us on Facebook"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12.07C22 6.48 17.52 2 11.93 2 6.35 2 1.87 6.48 1.87 12.07c0 4.77 3.44 8.73 7.94 9.64v-6.82H7.5v-2.82h2.31v-2.15c0-2.29 1.36-3.56 3.45-3.56.99 0 2.02.18 2.02.18v2.22h-1.14c-1.12 0-1.47.7-1.47 1.42v1.89h2.5l-.4 2.82h-2.1v6.82c4.5-.91 7.94-4.87 7.94-9.64z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
    <div class="mt-16 border-t border-black/[0.06] pt-8">
      <p class="text-xs text-beige-500 text-center">
        © 2026 Blue Royale Beauty &amp; Spa. All rights reserved.
      </p>
    </div>
  </div>
</footer>

---
import { languages } from '../i18n/ui';
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import LanguagePicker from './LanguagePicker.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const navLinks = [
  { href: '/#filosofia', label: t('nav.about') },
  { href: '/#servicios', label: t('nav.services') },
  { href: '/#testimonios', label: t('nav.testimonials') },
  { href: '/#contacto', label: t('nav.contact') },
];
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent bg-transparent transition-all duration-300 ease-out"
  aria-label="Main navigation"
>
  <nav class="relative mx-auto flex max-w-7xl items-center justify-between px-4 py-5 sm:px-6 lg:px-8">
    <a
      href={translatePath('/')}
      class="navbar-logo absolute left-1/2 -translate-x-1/2 font-serif text-2xl font-semibold tracking-tight text-primary transition-colors duration-300 hover:text-accent md:static md:transform-none md:text-3xl"
    >
      Blue Royale Spa
    </a>

    <!-- Desktop menu -->
    <div class="hidden items-center gap-8 md:flex">
      <ul class="flex items-center gap-8" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={translatePath(link.href)}
              class="navbar-link text-sm font-medium text-primary/80 transition-colors duration-300 hover:text-primary"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="navbar-lang-picker">
        <LanguagePicker />
      </div>

      <button
        type="button"
        class="navbar-cta inline-flex items-center justify-center rounded-full border border-primary px-5 py-2.5 text-sm font-medium text-primary shadow-sm transition-all duration-300 hover:bg-accent hover:text-white hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-secondary"
        data-cal-link="/"
      >
        {t('nav.book')}
      </button>
    </div>

    <!-- Mobile menu button -->
    <button
      type="button"
      id="menu-toggle"
      class="navbar-link inline-flex items-center justify-center rounded-spa p-2 text-primary md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg id="icon-menu" class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="hidden h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-cream-200/20 bg-primary/95 backdrop-blur-md md:hidden"
    aria-hidden="true"
  >
    <ul class="flex flex-col gap-0 px-4 py-4" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={translatePath(link.href)}
            class="block border-b border-black/[0.04] py-4 text-base font-medium text-secondary/80 transition-colors duration-300 hover:text-secondary"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="border-b border-black/[0.04]" aria-label="Idioma / Language">
        <div class="flex flex-col gap-0 py-2">
          {Object.entries(languages).map(([id, name]) => (
            <a
              href={translatePath('/', id)}
              data-lang-link
              class:list={[
                'block py-3 px-4 text-base font-medium transition-colors',
                id === lang ? 'text-secondary font-semibold' : 'text-secondary/80 hover:text-secondary',
              ]}
            >
              {name}
            </a>
          ))}
        </div>
      </li>
      <li class="pt-2">
        <button
          type="button"
          class="navbar-cta-mobile inline-flex w-full items-center justify-center rounded-full border border-secondary bg-transparent px-5 py-3 text-base font-medium text-secondary transition-colors duration-300 hover:bg-accent hover:text-white hover:border-accent focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 focus:ring-offset-primary"
          data-cal-link="/"
        >
          {t('nav.book')}
        </button>
      </li>
    </ul>
  </div>
</header>

<script>
  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  function updateNavbarScroll() {
    if (window.scrollY > 40) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  }

  function toggleMobileMenu() {
    const isOpen = mobileMenu?.classList.toggle('hidden');
    const menuIsVisible = !isOpen;
    menuToggle?.setAttribute('aria-expanded', String(menuIsVisible));
    mobileMenu?.setAttribute('aria-hidden', String(!menuIsVisible));
    iconMenu?.classList.toggle('hidden', menuIsVisible);
    iconClose?.classList.toggle('hidden', !menuIsVisible);
    document.body.style.overflow = menuIsVisible ? 'hidden' : '';
  }

  window.addEventListener('scroll', updateNavbarScroll, { passive: true });
  updateNavbarScroll();

  menuToggle?.addEventListener('click', toggleMobileMenu);
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      iconMenu?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      menuToggle?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });

  /** Solo menú móvil: el LanguagePicker de escritorio maneja sus propios enlaces (evita doble navigate). Recarga completa evita página en blanco con View Transitions. */
  mobileMenu?.querySelectorAll('[data-lang-link]').forEach((link) => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      window.location.assign((link as HTMLAnchorElement).href);
    });
  });

  function normalizePathname(pathname: string): string {
    if (!pathname || pathname === '/') return '/';
    return pathname.endsWith('/') ? pathname.slice(0, -1) : pathname;
  }

  /** Mismo destino que la home actual: scroll arriba (y quitar #) en lugar de recargar */
  const logoLink = document.querySelector('a.navbar-logo');
  logoLink?.addEventListener('click', (e) => {
    const a = e.currentTarget as HTMLAnchorElement;
    let targetPath = '';
    try {
      targetPath = new URL(a.getAttribute('href') || '', window.location.origin).pathname;
    } catch {
      return;
    }
    if (normalizePathname(window.location.pathname) !== normalizePathname(targetPath)) return;

    e.preventDefault();
    mobileMenu?.classList.add('hidden');
    mobileMenu?.setAttribute('aria-hidden', 'true');
    iconMenu?.classList.remove('hidden');
    iconClose?.classList.add('hidden');
    menuToggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (window.location.hash) {
      history.replaceState(null, '', window.location.pathname + window.location.search);
    }
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Navegación suave para enlaces de la home (inicio, secciones con #...)
  if (location.pathname === '/' || location.pathname === '/es/' || location.pathname === '/en/') {
    const internalLinks = document.querySelectorAll('#navbar a[href*="/#"]');
    internalLinks.forEach((link) => {
      link.addEventListener('click', (event) => {
        const href = link.getAttribute('href') || '';
        if (href.includes('#')) {
          event.preventDefault();
          const id = href.split('#')[1];
          const target = document.getElementById(id);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  }
</script>

<style>
  header.scrolled {
    @apply bg-primary/80 border-black/[0.05];
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  header.scrolled .navbar-logo {
    @apply text-secondary;
  }
  header.scrolled .navbar-link {
    @apply text-secondary/80;
  }
  header.scrolled .navbar-link:hover {
    @apply text-secondary;
  }
  header.scrolled .navbar-lang-picker :global(button) {
    @apply text-secondary/80;
  }
  header.scrolled .navbar-lang-picker :global(button:hover) {
    @apply text-secondary;
  }
  header.scrolled .navbar-cta {
    @apply border-secondary text-secondary bg-transparent;
  }
  header.scrolled .navbar-cta:hover {
    @apply bg-accent text-white border-accent;
  }
</style>

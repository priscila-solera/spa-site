---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="filosofia"
  class="scroll-mt-20 bg-primary px-4 py-16 sm:px-6 sm:py-16 lg:px-8"
  aria-labelledby="filosofia-heading"
>
  <div class="mx-auto max-w-6xl grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
    <div
      class="text-left"
      data-scroll-reveal="left"
    >
      <p class="editorial-subtitle text-accent">{t('philosophy.subtitle')}</p>
      <h2 id="filosofia-heading" class="section-heading mt-3">
        {t('philosophy.title')}
      </h2>
      <p class="mt-6 text-lg text-beige-600 leading-relaxed">
        {t('philosophy.intro1')}
      </p>
      <p class="mt-4 text-base text-beige-600 leading-relaxed">
        {t('philosophy.intro2')}
      </p>
      <ul class="mt-8 grid gap-4 text-sm text-beige-700 sm:grid-cols-2">
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-brandGold flex-shrink-0" aria-hidden="true" />
          <span>{t('philosophy.list1')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-brandGold flex-shrink-0" aria-hidden="true" />
          <span>{t('philosophy.list2')}</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-1.5 h-1.5 w-1.5 rounded-full bg-brandGold flex-shrink-0" aria-hidden="true" />
          <span>{t('philosophy.list3')}</span>
        </li>
      </ul>
    </div>

    <div
      class="relative px-4 pb-14 sm:px-10 sm:pb-10"
      data-scroll-reveal="right"
      data-scroll-delay="0.12s"
    >
      <div
        class="relative overflow-hidden rounded-2xl border border-black/[0.06] bg-cream-100 shadow-spa-soft"
        data-parallax
        data-parallax-speed-y="0.45"
        data-parallax-intensity="45"
      >
        <img
          src="/images/priscila.png"
          alt={t('philosophy.priscila.name')}
          class="h-full w-full object-cover object-top aspect-[4/5]"
          loading="lazy"
          width="600"
          height="750"
        />
      </div>
      <div
        class="absolute -bottom-24 left-0 right-0 rounded-2xl border border-black/[0.06] bg-cream-50/95 px-6 py-5 shadow-spa-md backdrop-blur-sm sm:left-10 sm:-bottom-14"
        data-parallax
        data-parallax-speed-y="-0.25"
        data-parallax-intensity="35"
      >
        <p class="font-sans font-semibold text-secondary text-base">
          {t('philosophy.priscila.name')}
        </p>
        <p class="mt-2 text-sm text-beige-700 leading-relaxed">
          {t('philosophy.priscila.bio')}
        </p>
      </div>
    </div>
  </div>
</section>

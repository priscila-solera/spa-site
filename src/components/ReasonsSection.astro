---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  id="por-que-elegirnos"
  class="scroll-mt-20 bg-secondary px-4 py-24 sm:px-6 sm:py-32 lg:px-8"
  aria-labelledby="reasons-heading"
>
  <div class="mx-auto max-w-7xl grid gap-16 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] lg:items-center">
    <div
      class="grid gap-4 sm:grid-cols-2"
      data-scroll-reveal="left"
    >
      <div
        class="overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-spa-soft"
        data-parallax
        data-parallax-speed-y="0.5"
        data-parallax-intensity="45"
      >
        <img
          src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=900&q=80&auto=format&fit=crop"
          alt="Massage table with soft towels and warm lighting."
          class="h-full w-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-500"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col gap-4">
        <div
          class="overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-spa-soft"
          data-parallax
          data-parallax-speed-y="-0.3"
          data-parallax-intensity="40"
        >
          <img
            src="https://images.unsplash.com/photo-1599058945522-28d584b6f0ff?w=900&q=80&auto=format&fit=crop"
            alt="Detail of oils and natural spa products."
            class="h-full w-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-500"
            loading="lazy"
          />
        </div>
        <div
          class="overflow-hidden rounded-2xl border border-white/10 bg-white/5 shadow-spa-soft"
          data-parallax
          data-parallax-speed-y="0.2"
          data-parallax-intensity="30"
        >
          <img
            src="https://images.unsplash.com/photo-1556228578-8c89e6adf883?w=900&q=80&auto=format&fit=crop"
            alt="Spa ambiance with candles and earth-toned decor."
            class="h-full w-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-500"
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <div
      class="rounded-2xl border border-white/10 bg-white/5 px-6 py-10 shadow-spa-soft sm:px-10 backdrop-blur-sm"
      data-scroll-reveal="right"
      data-scroll-delay="0.12s"
    >
      <p class="editorial-subtitle text-accent">{t('reasons.subtitle')}</p>
      <h2 id="reasons-heading" class="section-heading mt-3 text-white">
        {t('reasons.title')}
      </h2>
      <p class="mt-6 text-base text-cream-100/80 leading-relaxed">
        {t('reasons.desc')}
      </p>
      <ul class="mt-8 space-y-4 text-sm text-cream-200/90">
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list1')}</span>
        </li>
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list2')}</span>
        </li>
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list3')}</span>
        </li>
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list4')}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

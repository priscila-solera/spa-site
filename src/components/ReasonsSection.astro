---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Prueba: solo 2 fotos (habitaciones) o las 4. En .env: PUBLIC_REASONS_IMAGES=2 o 4 (por defecto 2).
const numImages = Number(import.meta.env.PUBLIC_REASONS_IMAGES) || 2;
const twoImagesOnly = numImages === 2;
// Las 2 fotos de las habitaciones son image-2 (sala con vanity) e image-4 (sala con dos camas)
const roomImages = [
  { src: '/images/image-2.jpeg', alt: 'Ambiente del spa, sala de tratamientos.', speedY: '-0.3', intensity: 40 },
  { src: '/images/image-4.jpeg', alt: 'Salas de bienestar en Blue Royale Spa.', speedY: '-0.2', intensity: 35 },
];
const allImages = [
  { src: '/images/image-1.jpeg', alt: 'Blue Royale Spa experience.', speedY: '0.5', intensity: 45 },
  { src: '/images/image-2.jpeg', alt: 'Blue Royale Spa ambiance.', speedY: '-0.3', intensity: 40 },
  { src: '/images/image-3.jpeg', alt: 'Blue Royale Spa treatments.', speedY: '0.2', intensity: 30 },
  { src: '/images/image-4.jpeg', alt: 'Blue Royale Spa wellness.', speedY: '-0.2', intensity: 35 },
];
const imagesToShow = twoImagesOnly ? roomImages : allImages;
const gridClass = twoImagesOnly ? 'grid grid-cols-2 gap-4 sm:gap-6' : 'grid grid-cols-2 gap-4 sm:gap-6';
---

<section
  id="por-que-elegirnos"
  class="scroll-mt-20 bg-white px-4 pt-6 pb-12 sm:px-6 sm:pt-20 sm:pb-20 lg:px-8"
  aria-labelledby="reasons-heading"
>
  <div class="mx-auto max-w-7xl grid gap-16 lg:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)] lg:items-center">
    <div
      class={gridClass}
      data-scroll-reveal="left"
    >
      {imagesToShow.map((img, i) => (
        <div
          class="overflow-hidden rounded-2xl border border-black/8 bg-white/40 shadow-spa-soft"
          data-parallax
          data-parallax-speed-y={img.speedY}
          data-parallax-intensity={img.intensity}
        >
          <img
            src={img.src}
            alt={img.alt}
            class="h-full w-full object-cover aspect-[3/4] sm:aspect-[4/5] opacity-90 hover:opacity-100 transition-opacity duration-500"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <div
      class="rounded-2xl border border-black/[0.06] bg-gray-50 px-6 py-10 shadow-spa-soft sm:px-10"
      data-scroll-reveal="right"
      data-scroll-delay="0.12s"
    >
      <p class="editorial-subtitle text-accent">{t('reasons.subtitle')}</p>
      <h2 id="reasons-heading" class="section-heading mt-3 text-secondary">
        {t('reasons.title')}
      </h2>
      <p class="mt-6 text-base text-beige-700 leading-relaxed">
        {t('reasons.desc')}
      </p>
      <ul class="mt-8 space-y-4 text-sm text-beige-700">
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list1')}</span>
        </li>
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list2')}</span>
        </li>
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list3')}</span>
        </li>
        <li class="flex gap-4 items-start">
          <span class="mt-0.5 inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-accent text-[0.7rem] text-secondary font-bold" aria-hidden="true">
            ✓
          </span>
          <span>{t('reasons.list4')}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

---
import BookingButton from './BookingButton.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  services?: Array<{
    id: string;
    title: string;
    shortDescription?: string | null;
    description: string;
    image: string;
    imageAlt: string;
    order: number;
    price?: string;
    duration?: string;
    calLink?: string;
    ctaLabel?: string;
    ctaLink?: string;
    category?: { title: string; order: number };
    therapistOptions?: Array<{ id: string; name: string; calLink: string }>;
  }>;
  defaultCalLink?: string;
}

const { services = [], defaultCalLink = import.meta.env.PUBLIC_CAL_LINK ?? 'daniel-torres-calvo' } = Astro.props;

// Agrupar servicios por categoría
const groupedServices = services.reduce((acc, service) => {
  const catTitle = service.category?.title || 'General';
  const catOrder = service.category?.order || 999;

  if (!acc[catTitle]) {
    acc[catTitle] = { order: catOrder, items: [] };
  }
  acc[catTitle].items.push(service);
  return acc;
}, {});

// Categorías ordenadas para las pestañas
const sortedCategories = Object.entries(groupedServices)
  .map(([title, data]) => ({ title, ...data }))
  .sort((a, b) => a.order - b.order);

// Lista plana de servicios con categoría para el grid y el filtro
const servicesWithCategory = services.map((s) => ({
  ...s,
  categoryTitle: s.category?.title || 'General',
}));
---

<section
  id="servicios"
  class="scroll-mt-20 bg-cream-100 px-4 pt-24 pb-12 sm:px-6 sm:pt-20 sm:pb-20 lg:px-8"
  aria-labelledby="servicios-heading"
  data-reveal
>
  <div class="mx-auto max-w-7xl">
    <header class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 text-left lg:flex-row lg:items-end mb-16">
      <div>
        <p class="editorial-subtitle">{t('services.subtitle')}</p>
        <h2 id="servicios-heading" class="section-heading mt-3">
          {t('services.title')}
        </h2>
        <p class="mt-4 max-w-xl text-lg text-beige-600 leading-relaxed">
          {t('services.desc')}
        </p>
      </div>
      <p class="max-w-sm text-sm text-beige-600 leading-relaxed">
        {t('services.subdesc')}
      </p>
    </header>

    {servicesWithCategory.length > 0 ? (
      <div class="services-treatments">
        <!-- Pestañas horizontales con scroll (solo categorías, sin \"ALL\") -->
        <div class="treatments-tabs-wrapper border-b border-beige-200">
          <div class="treatments-tabs-scroll" role="tablist" aria-label={t('services.subtitle')}>
            {sortedCategories.map((category) => (
              <button
                type="button"
                role="tab"
                aria-selected="false"
                data-filter={category.title}
                class="treatments-tab"
              >
                {category.title}
              </button>
            ))}
            <span class="treatments-tabs-chevron" aria-hidden="true">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </div>
        </div>

        <!-- Grid de servicios (se filtran por JS) -->
        <ul
          id="services-grid"
          class="services-reveal services-grid grid gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-4 mt-12"
          role="list"
        >
          {servicesWithCategory.map((service, i) => (
            <li
              class="service-card group flex flex-col items-center text-center h-full"
              data-category={service.categoryTitle}
              data-delay={i % 4}
              data-direction={i % 2 === 0 ? 'left' : 'right'}
            >
              <div
                class="relative flex h-44 w-44 shrink-0 items-center justify-center overflow-hidden rounded-full bg-cream-100 shadow-spa-soft border-4 border-white"
                data-parallax
                data-parallax-speed-y="0.3"
                data-parallax-speed-x={i % 2 === 0 ? -0.12 : 0.12}
                data-parallax-intensity="35"
              >
                <img
                  src={service.image}
                  alt={service.imageAlt}
                  class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-110"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="mt-6 px-2 sm:px-4 flex flex-col flex-1 min-h-0 w-full">
                <h4 class="font-serif text-xl font-semibold tracking-tight text-beige-800">
                  {service.title}
                </h4>
                <p class="service-card-desc mt-3 text-sm text-beige-600 leading-relaxed flex-1">
                  {service.shortDescription ?? service.description}
                </p>
                <button
                  type="button"
                  class="service-read-more mt-3 text-sm font-medium text-accent hover:text-accent/90 transition-colors"
                  data-service-id={service.id}
                  data-open-modal
                >
                  {t('services.readMore')}
                </button>
                <BookingButton
                  calLink={service.calLink ?? defaultCalLink}
                  serviceId={service.id}
                  variant="text"
                  class="group/link mt-3 shrink-0 p-0 text-secondary transition-colors hover:text-accent font-medium"
                >
                  {service.ctaLabel || t('services.cta')}
                  <span class="ml-1.5 transition-transform duration-300 group-hover/link:translate-x-1" aria-hidden="true">→</span>
                </BookingButton>
              </div>
            </li>
          ))}
        </ul>

        <!-- Show more / show less -->
        <div id="show-more-container" class="mt-12 flex justify-center" style="display: none">
          <button
            type="button"
            id="show-more-btn"
            class="inline-flex items-center gap-2 rounded-full border border-beige-300 bg-white px-8 py-3 text-sm font-medium text-beige-700 shadow-sm transition-all hover:border-secondary hover:text-secondary hover:shadow-md"
            data-show-more-label={t('services.showMore')}
            data-show-less-label={t('services.showLess')}
          >
            <span id="show-more-label">{t('services.showMore')}</span>
            <svg id="show-more-icon" class="h-4 w-4 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Modal: detalle del servicio (duración, precio, descripción, política, contacto, reserva) -->
      <div
        id="service-modal"
        class="service-modal hidden fixed inset-0 z-[100] overflow-y-auto"
        role="dialog"
        aria-modal="true"
        aria-labelledby="service-modal-title"
        aria-hidden="true"
      >
        <div class="service-modal-backdrop fixed inset-0 bg-black/60 backdrop-blur-sm transition-opacity" data-close-modal></div>
        <div class="service-modal-panel fixed left-1/2 top-1/2 z-10 w-full max-w-2xl -translate-x-1/2 -translate-y-1/2 px-4 sm:px-6 max-h-[90vh] flex flex-col items-center justify-start py-8">
          <div class="service-modal-card relative w-full rounded-2xl bg-cream-100 shadow-2xl border border-beige-200 overflow-hidden flex flex-col max-h-[85vh]">
            <button
              type="button"
              class="absolute right-4 top-4 z-20 flex h-10 w-10 items-center justify-center rounded-full bg-white/90 text-beige-600 shadow-spa hover:bg-white hover:text-beige-800 transition-colors"
              aria-label={t('services.modalClose')}
              data-close-modal
            >
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
            <div class="service-modal-body overflow-y-auto flex-1 p-6 sm:p-8 pt-14">
              {servicesWithCategory.map((service) => (
                <div
                  class="service-modal-content hidden"
                  id={`modal-content-${service.id}`}
                  data-service-id={service.id}
                >
                  <!-- Imagen y título -->
                  <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 mb-6">
                    <div class="shrink-0 flex justify-center sm:justify-start">
                      <img
                        src={service.image}
                        alt={service.imageAlt}
                        class="h-40 w-40 sm:h-44 sm:w-44 rounded-full object-cover border-4 border-white shadow-spa-soft ring-2 ring-beige-200/50"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                    <div class="flex-1 min-w-0 text-center sm:text-left">
                      <h2 id="service-modal-title" class="font-serif text-2xl sm:text-3xl font-semibold text-beige-800 mb-3">
                        {service.title}
                      </h2>
                      {(service.duration || service.price) && (
                        <div class="flex flex-wrap gap-4 sm:gap-6 justify-center sm:justify-start text-sm">
                          {service.duration && (
                            <span class="inline-flex items-center gap-2 text-beige-600">
                              <svg class="h-4 w-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              <span class="font-medium text-beige-700">{t('services.duration')}:</span>
                              {service.duration}
                            </span>
                          )}
                          {service.price && (
                            <span class="inline-flex items-center gap-2 text-beige-600">
                              <svg class="h-4 w-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              <span class="font-medium text-beige-700">{t('services.price')}:</span>
                              {service.price}
                            </span>
                          )}
                        </div>
                      )}
                    </div>
                  </div>

                  <!-- Descripción larga (en modal); si no hay, se muestra la corta -->
                  <p class="text-beige-600 leading-relaxed text-sm sm:text-base mb-6 pb-6 border-b border-beige-200 whitespace-pre-line">
                    {service.description || service.shortDescription}
                  </p>

                  <!-- Política de cancelación -->
                  <div class="mb-6 pb-6 border-b border-beige-200">
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-beige-500 mb-2">
                      {t('services.cancellationPolicy')}
                    </h3>
                    <p class="text-sm text-beige-600 leading-relaxed">
                      {t('services.cancellationText')}
                    </p>
                  </div>

                  <!-- Datos de contacto -->
                  <div class="mb-8">
                    <h3 class="text-xs font-semibold uppercase tracking-wider text-beige-500 mb-3">
                      {t('services.contactDetails')}
                    </h3>
                    <ul class="space-y-2 text-sm text-beige-600" role="list">
                      <li class="flex items-start gap-3">
                        <svg class="h-4 w-4 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span>{t('services.contactAddress')}</span>
                      </li>
                      <li class="flex items-center gap-3">
                        <svg class="h-4 w-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                        </svg>
                        <a href={`tel:+${t('services.contactPhone').replace(/\D/g, '')}`} class="hover:text-accent transition-colors">{t('services.contactPhone')}</a>
                      </li>
                      <li class="flex items-center gap-3">
                        <svg class="h-4 w-4 text-accent shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                        </svg>
                        <a href={`mailto:${t('services.contactEmail')}`} class="hover:text-accent transition-colors break-all">{t('services.contactEmail')}</a>
                      </li>
                    </ul>
                  </div>

                  <!-- CTA reserva -->
                  <div class="flex justify-center">
                    <BookingButton
                      calLink={service.calLink ?? defaultCalLink}
                      serviceId={service.id}
                      variant="primary"
                      class="rounded-full px-10 py-4 text-base font-medium shadow-md hover:shadow-lg transition-shadow"
                    >
                      {service.ctaLabel || t('services.cta')}
                    </BookingButton>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    ) : (
      <div class="mt-20 text-center text-beige-500">
        <p>{t('services.loading')}</p>
      </div>
    )}
  </div>
</section>

<script>
  (function () {
    const section = document.querySelector('#servicios[data-reveal]');
    if (!section) return;

    const tabs = section.querySelectorAll('.treatments-tab');
    const cards = section.querySelectorAll('.service-card');
    const grid = section.querySelector('.services-grid');
    const showMoreContainer = section.querySelector('#show-more-container');
    const showMoreBtn = section.querySelector('#show-more-btn');
    const showMoreLabel = section.querySelector('#show-more-label');
    const showMoreIcon = section.querySelector('#show-more-icon');
    const INITIAL_COUNT = 8;
    let expanded = false;

    function applyShowMore(visibleCards) {
      visibleCards.forEach((card, idx) => {
        if (idx >= INITIAL_COUNT) {
          card.setAttribute('data-show-more-hidden', '');
          card.style.display = 'none';
        }
      });
      if (showMoreContainer) {
        showMoreContainer.style.display = visibleCards.length > INITIAL_COUNT ? 'flex' : 'none';
      }
    }

    function setActiveTab(activeButton) {
      const filter = activeButton.getAttribute('data-filter') ?? '';
      expanded = false;

      tabs.forEach((tab) => {
        const isActive = tab === activeButton;
        tab.classList.toggle('treatments-tab--active', isActive);
        tab.setAttribute('aria-selected', String(isActive));
      });

      // Reset show-more state
      cards.forEach((card) => card.removeAttribute('data-show-more-hidden'));

      // Apply category filter
      cards.forEach((card) => {
        const category = card.getAttribute('data-category') ?? '';
        const show = filter === '' || category === filter;
        card.style.display = show ? '' : 'none';
      });

      // Apply show-more limit
      const visibleCards = Array.from(cards).filter((c) => c.style.display !== 'none');
      applyShowMore(visibleCards);

      // Reset button label/icon
      if (showMoreLabel && showMoreBtn) {
        showMoreLabel.textContent = showMoreBtn.getAttribute('data-show-more-label');
      }
      if (showMoreIcon) showMoreIcon.style.transform = '';

      if (grid) {
        grid.classList.remove('revealed');
        grid.classList.add('revealed');
      }
    }

    if (showMoreBtn && showMoreContainer) {
      showMoreBtn.addEventListener('click', () => {
        if (!expanded) {
          // Expand: show all hidden cards
          cards.forEach((card) => {
            if (card.hasAttribute('data-show-more-hidden')) {
              card.removeAttribute('data-show-more-hidden');
              card.style.display = '';
            }
          });
          expanded = true;
          if (showMoreLabel) showMoreLabel.textContent = showMoreBtn.getAttribute('data-show-less-label');
          if (showMoreIcon) showMoreIcon.style.transform = 'rotate(180deg)';
        } else {
          // Collapse: hide cards beyond initial count
          const visibleCards = Array.from(cards).filter((c) => c.style.display !== 'none');
          applyShowMore(visibleCards);
          expanded = false;
          if (showMoreLabel) showMoreLabel.textContent = showMoreBtn.getAttribute('data-show-more-label');
          if (showMoreIcon) showMoreIcon.style.transform = '';
          // Scroll back to top of grid
          if (grid) grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => setActiveTab(tab));
    });

    // Seleccionar por defecto la primera categoría
    if (tabs.length > 0) {
      setActiveTab(tabs[0]);
    }

    // Modal: abrir/cerrar
    const modal = section.querySelector('#service-modal');
    const openButtons = section.querySelectorAll('[data-open-modal]');
    const closeButtons = section.querySelectorAll('[data-close-modal]');
    const contents = section.querySelectorAll('.service-modal-content');

    let lastTrigger = null;

    function openModal(serviceId) {
      if (!modal) return;
      contents.forEach((el) => {
        el.classList.toggle('hidden', el.getAttribute('data-service-id') !== serviceId);
      });
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      // Move focus to first focusable element inside modal
      const focusable = modal.querySelectorAll(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      if (focusable.length) focusable[0].focus();
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      // Return focus to the button that opened the modal
      if (lastTrigger) {
        lastTrigger.focus();
        lastTrigger = null;
      }
    }

    openButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-service-id');
        if (id) {
          lastTrigger = btn;
          openModal(id);
        }
      });
    });

    closeButtons.forEach((el) => el.addEventListener('click', closeModal));

    document.addEventListener('keydown', (e) => {
      if (!modal || modal.classList.contains('hidden')) return;
      if (e.key === 'Escape') { closeModal(); return; }
      if (e.key === 'Tab') {
        const focusable = Array.from(modal.querySelectorAll(
          'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
        ));
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    });

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const list = section.querySelector('.services-reveal');
            if (list) list.classList.add('revealed');
          }
        });
      },
      { rootMargin: '0px 0px -100px 0px', threshold: 0.1 }
    );
    observer.observe(section);
  })();
</script>

<style>
  .treatments-tabs-wrapper {
    overflow: hidden;
  }

  .treatments-tabs-scroll {
    display: flex;
    align-items: center;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 1px; /* para que el borde activo no se corte */
  }

  .treatments-tabs-scroll::-webkit-scrollbar {
    display: none;
  }

  .treatments-tab {
    flex-shrink: 0;
    padding: 0.75rem 1rem 1rem;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: theme('colors.beige.500');
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
    white-space: nowrap;
  }

  .treatments-tab:hover {
    color: theme('colors.beige.700');
  }

  .treatments-tab--active {
    color: theme('colors.secondary');
    border-bottom-color: theme('colors.secondary');
  }

  .treatments-tabs-chevron {
    flex-shrink: 0;
    margin-left: 0.5rem;
    padding: 0.5rem;
    color: theme('colors.beige.400');
    pointer-events: none;
  }

  .services-grid {
    align-items: stretch;
  }

  .services-reveal .service-card {
    opacity: 0;
    transform: translate3d(0, 32px, 0) scale(0.96);
  }
  .services-reveal.revealed .service-card {
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.19, 1, 0.22, 1);
    animation-fill-mode: forwards;
    animation-name: serviceRevealCenter;
  }
  .services-reveal.revealed .service-card[data-direction="left"] {
    animation-name: serviceRevealFromLeft;
  }
  .services-reveal.revealed .service-card[data-direction="right"] {
    animation-name: serviceRevealFromRight;
  }
  .services-reveal.revealed .service-card[data-delay="0"] { animation-delay: 0s; }
  .services-reveal.revealed .service-card[data-delay="1"] { animation-delay: 0.12s; }
  .services-reveal.revealed .service-card[data-delay="2"] { animation-delay: 0.24s; }
  .services-reveal.revealed .service-card[data-delay="3"] { animation-delay: 0.36s; }

  @keyframes serviceRevealCenter {
    0% {
      opacity: 0;
      transform: translate3d(0, 32px, 0) scale(0.96);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes serviceRevealFromLeft {
    0% {
      opacity: 0;
      transform: translate3d(-60px, 30px, 0) scale(0.9);
    }
    60% {
      opacity: 1;
      transform: translate3d(6px, -6px, 0) scale(1.02);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }

  @keyframes serviceRevealFromRight {
    0% {
      opacity: 0;
      transform: translate3d(60px, 30px, 0) scale(0.9);
    }
    60% {
      opacity: 1;
      transform: translate3d(-6px, -6px, 0) scale(1.02);
    }
    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) scale(1);
    }
  }
  /* Descripción limitada a 4 líneas para tarjetas uniformes y CTA alineado */
  .service-card-desc {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 4rem; /* ~3 líneas de text-sm leading-relaxed */
  }

  .service-modal:not(.hidden) {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .service-modal-content:not(.hidden) {
    display: block;
  }
</style>

---
import { getPlaceReviews } from '../lib/googlePlaces.js';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const placeId = import.meta.env.PUBLIC_GOOGLE_PLACE_ID ?? 'ChIJlSq-Tts5no8RFNWJ7oxh7AE';
const apiKey = import.meta.env.PUBLIC_GOOGLE_PLACES_API_KEY ?? '';
const data = placeId && apiKey ? await getPlaceReviews(placeId, apiKey, lang) : null;
const reviews = data?.reviews ?? [];
const placeName = data?.placeName ?? 'Google Maps';
const placeUrl = data?.placeUrl ?? 'https://www.google.com/maps/search/Blue+Royale+Spa+Tamarindo';
const hasReviews = reviews.length > 0;
const GOLD = '#b8956e';
// Texto máximo por reseña en la tarjeta (las fotos de Google no cargan en sitios externos, usamos inicial)
const MAX_REVIEW_CHARS = 220;
function truncateReview(text) {
  if (!text || text.length <= MAX_REVIEW_CHARS) return text;
  return text.slice(0, MAX_REVIEW_CHARS).trim().replace(/\s+\S*$/, '') + '…';
}
---

<section
  id="testimonios"
  class="scroll-mt-20 border-t border-black/[0.03] bg-primary px-4 pt-12 pb-8 sm:px-6 sm:pt-20 sm:pb-20 lg:px-8"
  aria-labelledby="testimonios-heading"
>
  <div class="mx-auto max-w-7xl">
    <header
      class="mx-auto max-w-2xl text-center"
      data-scroll-reveal="up"
    >
      <p class="editorial-subtitle">{t('testimonials.subtitle')}</p>
      <h2 id="testimonios-heading" class="section-heading mt-3">
        {t('testimonials.title')}
      </h2>
      <p class="mt-4 text-lg text-beige-600 leading-relaxed">
        {t('testimonials.desc')}
      </p>
    </header>

    {hasReviews ? (
      <>
        <ul
          class="mt-20 grid gap-8 sm:grid-cols-2 lg:grid-cols-3"
          role="list"
        >
          {reviews.map((r, idx) => (
            <li
              class="flex flex-col rounded-2xl border border-black/[0.04] bg-white p-8 shadow-sm transition-all duration-300 hover:shadow-spa-md hover:-translate-y-1"
              data-scroll-reveal={idx % 2 === 0 ? 'left' : 'right'}
              data-scroll-delay={idx * 0.08 + 's'}
            >
              <div class="flex items-center gap-4">
                <div
                  class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-beige-200 text-beige-700 font-semibold border border-black/[0.06]"
                  aria-hidden="true"
                >
                  <span class="text-lg">{r.authorName.charAt(0).toUpperCase()}</span>
                </div>
                <div class="min-w-0 flex-1">
                  <cite class="not-italic font-medium text-beige-800">{r.authorName}</cite>
                  {r.relativeTime && (
                    <p class="text-xs text-beige-400 uppercase tracking-wide mt-0.5">{r.relativeTime}</p>
                  )}
                </div>
                <div
                  role="img"
                  aria-label={lang === 'es' ? `${r.rating} de 5 estrellas` : `${r.rating} out of 5 stars`}
                  class="flex gap-0.5"
                >
                  {[1, 2, 3, 4, 5].map((star) => (
                    <svg
                      class="h-4 w-4"
                      viewBox="0 0 20 20"
                      fill={star <= Math.round(r.rating) ? GOLD : '#e8e2d8'}
                      aria-hidden="true"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <blockquote class="mt-6 flex-1 font-serif text-base leading-relaxed text-beige-600 italic line-clamp-5">
                "{truncateReview(r.text)}"
              </blockquote>
            </li>
          ))}
        </ul>
        <div class="mt-16 flex justify-center">
          <a
            href={placeUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-beige-200 bg-white px-8 py-3 text-sm font-medium text-beige-700 shadow-sm transition-all duration-300 hover:border-gold/50 hover:bg-cream-50 hover:text-beige-900 hover:shadow-md"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            {t('testimonials.google')}
          </a>
        </div>
      </>
    ) : (
      <div class="mt-16 text-center">
        <p class="text-beige-500 mb-8">
          {t('testimonials.config')}
        </p>
        <a
          href={placeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-beige-200 bg-white px-8 py-3 text-sm font-medium text-beige-700 shadow-sm transition-all duration-300 hover:border-gold/50 hover:bg-cream-50 hover:text-beige-900 hover:shadow-md"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          {t('testimonials.google')}
        </a>
      </div>
    )}
  </div>
</section>

---
import { fetchReviews } from '../lib/sanity.js';

const reviews = await fetchReviews();
const hasReviews = Array.isArray(reviews) && reviews.length > 0;
---
<section
  id="testimonios"
  class="scroll-mt-20 border-t border-beige-200/50 bg-cream-50 px-4 py-24 sm:px-6 sm:py-32 lg:px-8"
  aria-labelledby="testimonios-heading"
>
  <div class="mx-auto max-w-7xl">
    <header class="mx-auto max-w-2xl text-center">
      <p class="editorial-subtitle">Lo que dicen</p>
      <h2 id="testimonios-heading" class="section-heading mt-2">
        Testimonios
      </h2>
      <p class="mt-4 text-base text-beige-500">
        Experiencias de nuestros clientes en Blue Royale Spa.
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
        <a
          href="https://www.google.com/maps/search/Blue+Royale+Spa+Tamarindo"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full border border-beige-200 bg-cream-100 px-4 py-2 text-sm text-beige-600 shadow-sm transition-colors hover:border-brandGold/40 hover:bg-cream-200"
          aria-label="Ver reseñas en Google"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          <span>Google Reviews</span>
        </a>
      </div>
    </header>

    {hasReviews ? (
      <ul
        class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3"
        role="list"
      >
        {reviews.map((r) => (
          <li
            class="rounded-2xl border border-black/[0.06] bg-cream-100 p-6 shadow-sm transition-shadow hover:shadow-md sm:p-8"
          >
            <div class="flex gap-1 text-brandGold" aria-hidden="true">
              {Array.from({ length: Math.min(5, r.stars) }).map(() => (
                <span aria-hidden="true">★</span>
              ))}
            </div>
            <blockquote class="mt-4 font-serif text-lg leading-relaxed text-beige-600">
              "{r.text}"
            </blockquote>
            <footer class="mt-4 flex items-center justify-between">
              <cite class="not-italic font-medium text-beige-700">{r.author}</cite>
              {r.date && (
                <time class="text-sm text-beige-500" datetime={r.date}>
                  {new Date(r.date).toLocaleDateString('es-CR', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              )}
            </footer>
          </li>
        ))}
      </ul>
    ) : (
      <p class="mt-12 text-center text-beige-500">
        Próximamente más testimonios. Síguenos en Google para dejar tu reseña.
      </p>
    )}
  </div>
</section>

---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Reservar Cita | Blue Royale Spa"
  description="Reserva tu cita en Blue Royale Spa. Masajes, faciales y rituales holísticos en Tamarindo, Costa Rica."
>
  <section class="px-4 py-24 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="font-serif text-3xl font-medium tracking-tight text-beige-500 sm:text-4xl">
        Reservar cita
      </h1>
      <p class="mt-4 text-beige-400">
        Próximamente podrás reservar aquí. Mientras tanto, contáctanos por WhatsApp o email.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a
          href="https://wa.me/50684872727"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center rounded-spa-lg bg-eucalyptus-600 px-6 py-3 text-sm font-medium text-cream-50 shadow-spa hover:bg-eucalyptus-500"
        >
          WhatsApp 506 8487 2727
        </a>
        <a
          href="mailto:blueroyalespa@gmail.com"
          class="inline-flex items-center rounded-spa-lg border border-beige-300 bg-transparent px-6 py-3 text-sm font-medium text-beige-500 hover:bg-cream-100"
        >
          blueroyalespa@gmail.com
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
